{
  "name": "gkapp",
  "productName": "GKApp",
  "version": "1.1.2",
  "private": true,
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "generate:assets": "node scripts/generate-assets.js",
    "generate:icons": "node scripts/generate-icons.js",
    "compress:images": "node scripts/compress-images.js",
    "predev": "node scripts/generate-assets.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build && electron-builder",
    "electron:build:win": "electron-vite build && electron-builder --win --publish never",
    "electron:build:mac": "electron-vite build && electron-builder --mac --publish never",
    "electron:build:linux": "electron-vite build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.gkapp.app",
    "productName": "GKApp",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "adriandocampo",
      "repo": "GKapp",
      "releaseType": "release"
    },
    "generateUpdatesFilesForAllChannels": true,
    "files": [
      "dist-electron/main/**/*",
      "dist-electron/preload/**/*",
      "dist-electron/renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.sports"
    },
    "dmg": {
      "writeUpdateInfo": false,
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "dom-to-image-more": "^3.7.2",
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^6.0.0-beta.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "wait-on": "^8.0.1"
  }
}
