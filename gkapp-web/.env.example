# ─────────────────────────────────────────
# GKApp – Web deployment environment vars
# Copy this file to .env.local for local dev
# Add all of these as GitHub Repository Secrets
# for the CI/CD deploy-web.yml workflow
# ─────────────────────────────────────────

# Firebase project (https://console.firebase.google.com)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# YouTube Data API v3 – OAuth 2.0 Client ID (type: Web Application)
# https://console.cloud.google.com → APIs & Services → Credentials
VITE_YOUTUBE_CLIENT_ID=
